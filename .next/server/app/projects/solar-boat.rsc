0:["YyXNSnF8WZywAGyy9EFLU",[[["",{"children":["projects",{"children":[["slug","solar-boat","d"],{"children":["__PAGE__?{\"slug\":\"solar-boat\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["projects",{"children":[["slug","solar-boat","d"],{"children":["__PAGE__",{},[["$L1",["$","main",null,{"className":"px-6 py-16","children":["$","div",null,{"className":"mx-auto max-w-[800px]","children":[["$","$L2",null,{"href":"/#hardware","className":"mb-12 inline-block text-[13px] text-secondary transition-colors hover:text-primary","children":"← All projects"}],["$","p",null,{"className":"mb-3 font-mono text-[12px] font-medium text-accent","children":"$$26k Yamaha Grant · Junior Capstone · Spring 2025"}],["$","h1",null,{"className":"mb-4 text-[36px] font-semibold leading-tight text-primary sm:text-[44px]","children":"Solar Boat"}],["$","div",null,{"className":"mb-10 flex flex-wrap gap-2","children":[["$","span","Electrical Systems",{"className":"rounded-full bg-tag-bg px-2.5 py-0.5 font-mono text-[11px] text-accent","children":"Electrical Systems"}],["$","span","Solar",{"className":"rounded-full bg-tag-bg px-2.5 py-0.5 font-mono text-[11px] text-accent","children":"Solar"}],["$","span","Fusion 360",{"className":"rounded-full bg-tag-bg px-2.5 py-0.5 font-mono text-[11px] text-accent","children":"Fusion 360"}],["$","span","Carpentry",{"className":"rounded-full bg-tag-bg px-2.5 py-0.5 font-mono text-[11px] text-accent","children":"Carpentry"}],["$","span","Torqeedo",{"className":"rounded-full bg-tag-bg px-2.5 py-0.5 font-mono text-[11px] text-accent","children":"Torqeedo"}],["$","span","Project Lead",{"className":"rounded-full bg-tag-bg px-2.5 py-0.5 font-mono text-[11px] text-accent","children":"Project Lead"}]]}],["$","div",null,{"className":"relative mb-16 aspect-[16/9] w-full overflow-hidden rounded-[10px]","children":["$","$L3",null,{"src":"/images/solarboat-images/solar-boat-hero.jpg","alt":"Drone shot of solar boat on lake at dusk with moody sky","fill":true,"className":"object-cover","priority":true}]}],["$","div",null,{"className":"mb-16","children":[["$","h2",null,{"className":"mb-4 text-[20px] font-semibold text-primary","children":"What it is"}],["$","div",null,{"className":"space-y-4 text-[15px] leading-[1.75] text-secondary","children":[["$","p",null,{"children":"Boating accounts for roughly 3% of global greenhouse emissions. Electric boats exist but the technology is expensive and largely out of reach for recreational use. Phillip Mann and I wanted to know if two physics students with limited funding and a beat-up pontoon hull could change that, at least at small scale."}],["$","p",null,{"children":"The answer was yes... eventually. We spent a semester converting a 1970s Davidson College pontoon boat into a fully solar-powered vessel: three 200W solar panels charging a pair of 48V Torqeedo batteries, driving a Cruise 6.0 RS electric outboard motor. The boat floats, drives, and runs entirely on sunlight."}]]}]]}],["$","div",null,{"className":"mb-16","children":[["$","h2",null,{"className":"mb-4 text-[20px] font-semibold text-primary","children":"How we made it happen"}],["$","div",null,{"className":"space-y-4 text-[15px] leading-[1.75] text-secondary","children":[["$","p",null,{"children":"We had an idea and almost nothing else. No budget, no boat, no motor."}],["$","p",null,{"children":"Getting a worksite meant cold-emailing the Lake Campus director, who told us there were two abandoned pontoon hulls in the boatyard we could use. Getting a motor meant writing personalized sponsorship pitches to every electric marine company we could find. Nine companies didn't respond. Yamaha did. They had just launched their RightWaters sustainability campaign and recently acquired Torqeedo, a German electric outboard manufacturer. We got on a Zoom call. They liked the project. They sent us a $14,000 motor."}],["$","p",null,{"children":"The physics department funded the solar panels. The college sustainability office added another $1,500. We started the semester with enough to build."}]]}]]}],["$","div",null,{"className":"mb-16","children":[["$","h2",null,{"className":"mb-4 text-[20px] font-semibold text-primary","children":"Building it"}],["$","div",null,{"className":"space-y-6 text-[15px] leading-[1.75] text-secondary","children":[["$","div",null,{"className":"relative aspect-[4/3] w-full overflow-hidden rounded-[10px]","children":["$","$L3",null,{"src":"/images/solarboat-images/solar-boat-progress.jpg","alt":"Nearly complete boat in boatyard with ladder leaning against it and blue sky","fill":true,"className":"object-cover"}]}],["$","p",null,{"children":"The boat hadn't been in the water in over a decade. We spent the first weeks tearing it down — rusted bolts, rotting carpet, a dead gas motor. Then rebuilt from the floor up: new carpet, benches, plywood walls, roof structure, a back deck, ladder, cleats, and a captain's chair."}],["$","div",null,{"className":"relative aspect-[4/3] overflow-hidden rounded-[10px] sm:w-1/2","children":["$","$L3",null,{"src":"/images/solarboat-images/solar-boat-building.jpg","alt":"Person drilling into roof frame in boatyard with other boats in background","fill":true,"className":"object-cover"}]}],["$","p",null,{"children":"The roof was the structural centerpiece. It needed to hold three solar panels and double as a lounge area people could actually sit on, so it had to be over-engineered. We extended it a foot and a half past the boat's footprint on each side to maximize panel coverage, which required some interesting carpentry at the corners to keep it from racking."}],["$","p",null,{"children":"The electrical system ran three Renogy 200W panels through a Torqeedo solar charge controller into two 48V batteries wired in parallel, powering the outboard motor. A separate 12V system ran lights, speakers, and a horn."}],["$","div",null,{"className":"relative aspect-[4/3] w-full overflow-hidden rounded-[10px]","children":["$","$L3",null,{"src":"/images/solarboat-images/solar-boat-panels.jpg","alt":"Person sitting on finished roof with two large solar panels laid out on either side, lake visible in background","fill":true,"className":"object-cover"}]}],["$","div",null,{"className":"relative aspect-[4/3] overflow-hidden rounded-[10px] sm:w-1/2","children":["$","$L3",null,{"src":"/images/solarboat-images/solar-boat-electrical.jpg","alt":"Torqeedo battery with clamp meter reading current on top","fill":true,"className":"object-cover"}]}],["$","div",null,{"children":[["$","div",null,{"className":"overflow-hidden rounded-[10px]","children":["$","video",null,{"autoPlay":true,"muted":true,"loop":true,"playsInline":true,"className":"w-full","children":["$","source",null,{"src":"/videos/solar-boat-motor.mp4","type":"video/mp4"}]}]}],["$","p",null,{"className":"mt-2 font-mono text-[12px] text-muted","children":"First time the motor ran."}]]}]]}]]}],["$","div",null,{"className":"mb-16","children":[["$","h2",null,{"className":"mb-4 text-[20px] font-semibold text-primary","children":"What went wrong"}],["$","div",null,{"className":"space-y-6 text-[15px] leading-[1.75] text-secondary","children":[["$","div",null,{"className":"relative aspect-[4/3] overflow-hidden rounded-[10px] sm:w-1/2","children":["$","$L3",null,{"src":"/images/solarboat-images/solar-boat-dock.jpg","alt":"Boat tied at dock under blue sky during first water test","fill":true,"className":"object-cover"}]}],["$","p",null,{"children":"The day before the symposium, we connected the third solar panel to the charge controller. Two panels had worked fine. Three panels pushed the input voltage to ~60V, which is above what the charge controller could handle. It fried one battery completely. The other threw a permanent fault code. We presented the next morning anyway, running on wall power."}],["$","p",null,{"children":"Yamaha sent us new batteries."}],["$","p",null,{"children":"The speaker system also died during final wiring. Running cables under a wet boat created a short we couldn't trace. We replaced everything under warranty."}]]}]]}],["$","div",null,{"className":"mb-16","children":[["$","h2",null,{"className":"mb-4 text-[20px] font-semibold text-primary","children":"What came of it"}],["$","div",null,{"className":"space-y-6 text-[15px] leading-[1.75] text-secondary","children":[["$","div",null,{"className":"relative aspect-[4/3] w-full overflow-hidden rounded-[10px]","children":["$","$L3",null,{"src":"/images/solarboat-images/verna-miller-case-symposium_010.jpg","alt":"Two people standing on finished painted boat with research poster at symposium","fill":true,"className":"object-cover"}]}],["$","p",null,{"children":"Top speed of 7mph with 4 people on board. Yamaha published a feature on the project for their RightWaters campaign. We presented at Davidson's Verna Miller Case Symposium to faculty, peers, and industry sponsors. The boat is still at the lake."}],["$","div",null,{"className":"flex flex-col gap-2 sm:flex-row sm:gap-6","children":[["$","a",null,{"href":"https://yamahaoutboards.com/newsroom/company-news/yamaha-rightwaters-sponsors-davidson-college-student-led-sustainable-marine-project","target":"_blank","rel":"noopener noreferrer","className":"text-[13px] font-medium text-accent transition-opacity hover:opacity-80","children":"Yamaha RightWaters writeup ↗"}],["$","a",null,{"href":"https://www.edtechinnovationhub.com/news/students-at-davidson-college-build-solar-powered-boat-in-yamaha-rightwaters-backed-project","target":"_blank","rel":"noopener noreferrer","className":"text-[13px] font-medium text-accent transition-opacity hover:opacity-80","children":"EdTech Innovation Hub coverage ↗"}]]}]]}]]}],["$","div",null,{"className":"border-t border-border pt-8","children":["$","$L2",null,{"href":"/projects/baja-sae","className":"text-[13px] font-medium text-accent transition-opacity hover:opacity-80","children":"Next project: Baja SAE →"}]}]]}]}],null],null],null]},[null,["$","$L4",null,{"parallelRouterKey":"children","segmen